# Declarative development environment input; do not install before review.
# There is deliberately no saveenv, sf, nand, DFU, or QSPI update command.
boot_targets=mmc0
neptune_kernel=zImage
neptune_fdt=p210.dtb
neptune_sdboot=fatload mmc 0:1 0x03000000 ${neptune_kernel}; fatload mmc 0:1 0x02a00000 ${neptune_fdt}; setenv bootargs console=ttyPS0,115200 root=/dev/mmcblk0p2 ro rootwait; bootz 0x03000000 - 0x02a00000
bootcmd=run neptune_sdboot
