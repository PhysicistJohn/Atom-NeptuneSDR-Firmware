{
  "schema": "neptunesdr.edge.data-schema/v1",
  "protocol": "Neptune Edge Data Plane v1",
  "status": "canonical wire contract",
  "wire": {
    "byte_order": "little-endian",
    "alignment_bytes": 4,
    "crc": {
      "algorithm": "CRC-32C (Castagnoli)",
      "reflected_polynomial": "0x82f63b78",
      "initial": "0xffffffff",
      "xor_out": "0xffffffff"
    }
  },
  "clock_model": {
    "timestamp_name": "ingress_sample_timestamp",
    "timestamp_bits": 64,
    "timestamp_timebase_hz": 61440000,
    "internal_sample_rate_hz": 61440000,
    "continuous_egress_sample_rate_hz": 55000000,
    "interpolation": 1375,
    "decimation": 1536,
    "ratio": "1375/1536",
    "exact_identity": "61440000 * 1375 / 1536 = 55000000",
    "mapping": "source_tick(k) = input_timestamp + floor((phase_numerator + k * decimation) / interpolation)",
    "next_state": "total = phase_numerator + sample_count * decimation; next_input_timestamp = input_timestamp + floor(total / interpolation); next_phase_numerator = total mod interpolation",
    "requirements": [
      "sample_timestamp is always expressed in 61.44 MHz ingress ticks, including 55 MHz products",
      "a 55 MHz packet MUST carry exactly one RESAMPLER_STATE extension",
      "RESAMPLER_STATE.input_timestamp MUST equal the base-header sample_timestamp",
      "phase_numerator MUST be less than interpolation and phase_denominator MUST equal interpolation",
      "output_sample_index increments by sample_count within a continuity epoch"
    ]
  },
  "rate_domains": {
    "RAW_IQ": {
      "sample_rate_hz": 61440000,
      "description": "native pre-correction bypass or DDR burst; no resampling is represented as raw"
    },
    "NORMALIZED_IQ": {
      "sample_rate_hz": 55000000,
      "description": "primary continuous Ethernet IQ product; RESAMPLER_STATE is mandatory"
    },
    "CALIBRATED_IQ": {
      "sample_rate_hz": [61440000, 55000000],
      "description": "may be tapped before or after rational egress conversion; 55 MHz requires RESAMPLER_STATE"
    },
    "requirements": [
      "every IQ packet carries RF_STATE",
      "RAW_IQ has calibration_revision zero",
      "CALIBRATED_IQ has a nonzero calibration_revision",
      "NORMALIZED_IQ uses the exact 55 MHz egress domain"
    ]
  },
  "base_header": {
    "magic_ascii": "NEDP",
    "version": 1,
    "size_bytes": 64,
    "header_length_unit_bytes": 4,
    "header_crc_field": "header_crc32c",
    "header_crc_rule": "CRC-32C over base header plus all extensions with header_crc32c encoded as zero",
    "fields": [
      {"name": "magic", "type": "bytes4", "offset": 0, "description": "ASCII NEDP"},
      {"name": "protocol_version", "type": "u8", "offset": 4, "description": "exactly 1"},
      {"name": "header_words", "type": "u8", "offset": 5, "description": "base plus extensions in four-byte words"},
      {"name": "packet_type", "type": "u8", "offset": 6, "description": "PacketType code"},
      {"name": "sample_format", "type": "u8", "offset": 7, "description": "SampleFormat code"},
      {"name": "flags", "type": "u32", "offset": 8, "description": "DataFlag bitset"},
      {"name": "stream_id", "type": "u32", "offset": 12, "description": "logical stream identifier"},
      {"name": "sequence_number", "type": "u64", "offset": 16, "description": "monotonic per stream; discontinuities do not reset it, but stream destruction and recreation may"},
      {"name": "sample_timestamp", "type": "u64", "offset": 24, "description": "61.44 MHz ingress sample counter associated with payload sample zero"},
      {"name": "sample_count", "type": "u32", "offset": 32, "description": "complex sample periods per enabled channel, never scalar component count"},
      {"name": "channel_mask", "type": "u16", "offset": 36, "description": "bit zero is RX1 and bit one is RX2"},
      {"name": "extension_count", "type": "u16", "offset": 38, "description": "number of typed extensions"},
      {"name": "payload_length", "type": "u32", "offset": 40, "description": "payload bytes excluding header and extensions"},
      {"name": "configuration_revision", "type": "u32", "offset": 44, "description": "configuration revision active at sample_timestamp"},
      {"name": "calibration_revision", "type": "u32", "offset": 48, "description": "calibration table revision active at sample_timestamp; zero means raw or none"},
      {"name": "discontinuity_revision", "type": "u32", "offset": 52, "description": "increments exactly once for every continuity break"},
      {"name": "device_state_revision", "type": "u32", "offset": 56, "description": "revision of temporally aligned RF and device state"},
      {"name": "header_crc32c", "type": "u32", "offset": 60, "description": "CRC-32C over the complete header with this field zero"}
    ]
  },
  "extension_header": {
    "size_bytes": 8,
    "length_unit_bytes": 4,
    "fields": [
      {"name": "type", "type": "u16", "offset": 0},
      {"name": "length_words", "type": "u16", "offset": 2},
      {"name": "flags", "type": "u32", "offset": 4}
    ],
    "rules": [
      "length_words includes the eight-byte extension header",
      "extensions appear in ascending type-code order",
      "unknown extensions are skipped using length_words",
      "v1 permits at most one extension of each type"
    ]
  },
  "enums": {
    "packet_type": {
      "NONE": 0,
      "RAW_IQ": 1,
      "CALIBRATED_IQ": 2,
      "NORMALIZED_IQ": 3,
      "FFT": 4,
      "STFT": 5,
      "DETECTOR_EVENT": 6,
      "TRIGGERED_CAPTURE": 7,
      "STATUS_SNAPSHOT": 8,
      "STATE_CHANGE": 9,
      "DISCONTINUITY": 10,
      "VALIDITY_MASK": 11,
      "DUAL_CHANNEL_PRODUCT": 12
    },
    "sample_format": {
      "NONE": 0,
      "S16": 1,
      "S12P": 2,
      "S8": 3,
      "S8BF": 4
    },
    "data_flag": {
      "DISCONTINUITY": 1,
      "END_OF_BURST": 2,
      "VALIDITY_MASK_PRESENT": 4,
      "CLIPPED": 8,
      "RETUNE": 16,
      "OVERFLOW": 32,
      "STATE_CHANGE": 64,
      "METADATA_COMPLETE": 128,
      "PAYLOAD_CRC_PRESENT": 256
    },
    "quantization_strategy": {
      "FIXED_SHIFT": 0,
      "PEAK": 1,
      "RMS": 2
    },
    "rounding_mode": {
      "ROUND_TO_NEAREST_EVEN": 1
    },
    "discontinuity_reason": {
      "UNSPECIFIED": 0,
      "SAMPLE_COUNTER_RESET": 1,
      "FIFO_OVERFLOW": 2,
      "DMA_OVERRUN": 3,
      "ETHERNET_BACKPRESSURE": 4,
      "RETUNE": 5,
      "GAIN_TRANSITION": 6,
      "FILTER_CHANGE": 7,
      "PIPELINE_RESTART": 8,
      "CLOCK_OR_INTERFACE_ERROR": 9,
      "CALIBRATION_ACTIVITY": 10
    },
    "discontinuity_action": {
      "MARK_ONLY": 0,
      "INVALIDATE_RANGE": 1,
      "STREAM_RESTARTED": 2
    },
    "state_change_kind": {
      "CONFIGURATION": 1,
      "CALIBRATION": 2,
      "RF_STATE": 3,
      "QUANTIZATION": 4,
      "PIPELINE": 5,
      "STREAM": 6
    },
    "state_scope": {
      "DEVICE": 0,
      "RX1": 1,
      "RX2": 2,
      "RX_BOTH": 3,
      "STREAM": 4
    },
    "changed_field": {
      "CENTER_FREQUENCY": 1,
      "SAMPLE_RATE": 2,
      "RF_BANDWIDTH": 4,
      "ANALOG_GAIN": 8,
      "FILTER": 16,
      "CALIBRATION": 32,
      "QUANTIZATION": 64,
      "DDC": 128,
      "DETECTOR": 256,
      "STREAM_DESTINATION": 512
    },
    "product_encoding": {
      "NONE": 0,
      "COMPLEX_I16": 1,
      "POWER_U32": 2,
      "LOG_POWER_I16_Q8_8": 3,
      "COMPACT_TILE_U8": 4,
      "VALIDITY_BITSET_LSB0": 5,
      "CROSS_COMPLEX_I32": 6
    },
    "window_kind": {
      "RECTANGULAR": 0,
      "HANN": 1,
      "BLACKMAN_HARRIS": 2,
      "FLAT_TOP": 3
    },
    "timestamp_reference": {
      "FIRST_SAMPLE": 0,
      "CENTER_SAMPLE": 1
    },
    "detector_event_kind": {
      "THRESHOLD_CROSSING": 1,
      "PEAK": 2,
      "OCCUPIED_BAND": 3,
      "PULSE": 4,
      "ENERGY": 5,
      "CLIPPING": 6
    },
    "trigger_source": {
      "SOFTWARE": 1,
      "DETECTOR": 2,
      "GPIO": 3,
      "TIMESTAMP": 4,
      "EXTERNAL_EVENT": 5
    },
    "dual_channel_product_kind": {
      "CROSS_SPECTRUM": 1,
      "RELATIVE_PHASE": 2,
      "RELATIVE_AMPLITUDE": 3,
      "COMPLEX_CORRELATION": 4,
      "DELAY_ESTIMATE": 5
    }
  },
  "extensions": {
    "RF_STATE": {
      "code": 1,
      "size_bytes": 48,
      "description": "device state temporally aligned with sample_timestamp",
      "fields": [
        {"name": "center_frequency_hz", "type": "u64", "offset": 8},
        {"name": "sample_rate_hz", "type": "u32", "offset": 16},
        {"name": "rf_bandwidth_hz", "type": "u32", "offset": 20},
        {"name": "rx1_gain_mdb", "type": "i32", "offset": 24},
        {"name": "rx2_gain_mdb", "type": "i32", "offset": 28},
        {"name": "digital_gain_q16_16", "type": "i32", "offset": 32},
        {"name": "temperature_mc", "type": "i32", "offset": 36},
        {"name": "rx1_gain_mode", "type": "u8", "offset": 40},
        {"name": "rx2_gain_mode", "type": "u8", "offset": 41},
        {"name": "pll_lock_mask", "type": "u8", "offset": 42},
        {"name": "channel_mask", "type": "u8", "offset": 43},
        {"name": "device_flags", "type": "u32", "offset": 44}
      ]
    },
    "QUANTIZATION": {
      "code": 2,
      "size_bytes": 40,
      "description": "deterministic normalization and quantization state; S8BF reconstruction is q * 2^exponent ADC codes",
      "fields": [
        {"name": "exponent", "type": "i8", "offset": 8},
        {"name": "headroom_bits", "type": "u8", "offset": 9},
        {"name": "strategy", "type": "u8", "offset": 10},
        {"name": "rounding", "type": "u8", "offset": 11},
        {"name": "scale_numerator", "type": "u32", "offset": 12},
        {"name": "scale_denominator", "type": "u32", "offset": 16},
        {"name": "block_rms_q16_16", "type": "u32", "offset": 20},
        {"name": "block_peak_q16_16", "type": "u32", "offset": 24},
        {"name": "clipping_count", "type": "u32", "offset": 28},
        {"name": "valid_sample_count", "type": "u32", "offset": 32},
        {"name": "invalid_sample_count", "type": "u32", "offset": 36}
      ],
      "requirements": [
        "required for S8BF",
        "q = saturate(round(x * scale_numerator / scale_denominator)); x is the pre-quantization ADC-domain component",
        "for S8BF, scale_numerator / scale_denominator equals 2^-exponent and reconstruction is q * 2^exponent ADC codes",
        "block RMS and peak are unsigned Q16.16 ADC-code magnitudes measured before quantization",
        "valid and invalid counts are complex channel samples; clipping_count counts saturated scalar I or Q components",
        "rounding is round-to-nearest-even and saturation uses signed two's-complement bounds [-128, 127]"
      ]
    },
    "RESAMPLER_STATE": {
      "code": 3,
      "size_bytes": 40,
      "description": "exact rational-rate mapping from payload samples to the 61.44 MHz ingress counter",
      "fields": [
        {"name": "input_rate_hz", "type": "u32", "offset": 8},
        {"name": "output_rate_hz", "type": "u32", "offset": 12},
        {"name": "interpolation", "type": "u16", "offset": 16},
        {"name": "decimation", "type": "u16", "offset": 18},
        {"name": "phase_numerator", "type": "u16", "offset": 20},
        {"name": "phase_denominator", "type": "u16", "offset": 22},
        {"name": "input_timestamp", "type": "u64", "offset": 24},
        {"name": "output_sample_index", "type": "u64", "offset": 32}
      ]
    },
    "DISCONTINUITY": {
      "code": 4,
      "size_bytes": 32,
      "description": "observable continuity break; UINT32_MAX lost_input_samples means unknown",
      "fields": [
        {"name": "reason", "type": "u16", "offset": 8},
        {"name": "action", "type": "u16", "offset": 10},
        {"name": "lost_input_samples", "type": "u32", "offset": 12},
        {"name": "last_good_timestamp", "type": "u64", "offset": 16},
        {"name": "first_valid_timestamp", "type": "u64", "offset": 24}
      ]
    },
    "STATE_CHANGE": {
      "code": 5,
      "size_bytes": 48,
      "description": "revision transition that becomes active on an exact ingress sample timestamp",
      "fields": [
        {"name": "change_kind", "type": "u16", "offset": 8},
        {"name": "scope", "type": "u16", "offset": 10},
        {"name": "reserved", "type": "u32", "offset": 12},
        {"name": "changed_fields", "type": "u64", "offset": 16},
        {"name": "previous_configuration_revision", "type": "u32", "offset": 24},
        {"name": "new_configuration_revision", "type": "u32", "offset": 28},
        {"name": "previous_calibration_revision", "type": "u32", "offset": 32},
        {"name": "new_calibration_revision", "type": "u32", "offset": 36},
        {"name": "activation_timestamp", "type": "u64", "offset": 40}
      ],
      "requirements": [
        "STATE_CHANGE packets carry no sample payload",
        "base sample_timestamp equals activation_timestamp",
        "the first affected data packet carries the new revisions"
      ]
    },
    "BLOCK_STATS": {
      "code": 6,
      "size_bytes": 32,
      "description": "measurement statistics before payload quantization; RMS and peak are unsigned Q16.16 ADC-code magnitudes, sample counts are complex channel samples, and clipping counts scalar I/Q components",
      "fields": [
        {"name": "rms_q16_16", "type": "u32", "offset": 8},
        {"name": "peak_q16_16", "type": "u32", "offset": 12},
        {"name": "clipping_count", "type": "u32", "offset": 16},
        {"name": "valid_sample_count", "type": "u32", "offset": 20},
        {"name": "invalid_sample_count", "type": "u32", "offset": 24},
        {"name": "reserved", "type": "u32", "offset": 28}
      ]
    },
    "VALIDITY_MASK": {
      "code": 7,
      "size_bytes": 32,
      "description": "layout and summary for a VALIDITY_MASK packet payload; one LSB-first bit describes each complex channel sample in time-major channel order",
      "fields": [
        {"name": "valid_sample_count", "type": "u32", "offset": 8},
        {"name": "invalid_sample_count", "type": "u32", "offset": 12},
        {"name": "first_sample_index", "type": "u32", "offset": 16},
        {"name": "bit_count", "type": "u32", "offset": 20},
        {"name": "encoding", "type": "u8", "offset": 24},
        {"name": "valid_bit_value", "type": "u8", "offset": 25},
        {"name": "reserved16", "type": "u16", "offset": 26},
        {"name": "reason_mask", "type": "u32", "offset": 28}
      ],
      "requirements": [
        "VALIDITY_MASK packets carry this extension and SampleFormat.NONE",
        "payload length is ceil(bit_count / 8)",
        "bit_count equals sample_count multiplied by popcount(channel_mask)"
      ]
    },
    "DDC_STATE": {
      "code": 8,
      "size_bytes": 32,
      "description": "DDC/NCO and decimation state active at the packet timestamp",
      "fields": [
        {"name": "nco_phase_increment", "type": "u32", "offset": 8},
        {"name": "center_offset_hz", "type": "i32", "offset": 12},
        {"name": "input_rate_hz", "type": "u32", "offset": 16},
        {"name": "output_rate_hz", "type": "u32", "offset": 20},
        {"name": "decimation", "type": "u32", "offset": 24},
        {"name": "ddc_revision", "type": "u32", "offset": 28}
      ]
    },
    "FFT_METADATA": {
      "code": 9,
      "size_bytes": 40,
      "description": "fixed FFT product layout; payload elements and scaling are explicit",
      "fields": [
        {"name": "fft_size", "type": "u32", "offset": 8},
        {"name": "bin_count", "type": "u32", "offset": 12},
        {"name": "first_bin", "type": "i32", "offset": 16},
        {"name": "window", "type": "u16", "offset": 20},
        {"name": "encoding", "type": "u8", "offset": 22},
        {"name": "stage_shift", "type": "u8", "offset": 23},
        {"name": "center_offset_hz", "type": "i32", "offset": 24},
        {"name": "output_rate_hz", "type": "u32", "offset": 28},
        {"name": "block_exponent", "type": "i16", "offset": 32},
        {"name": "reserved16", "type": "u16", "offset": 34},
        {"name": "overflow_count", "type": "u32", "offset": 36}
      ],
      "requirements": [
        "FFT packets carry exactly one FFT_METADATA extension",
        "sample_timestamp identifies the first time-domain sample of the transform",
        "payload length equals bin_count multiplied by the encoded element width and enabled channel count"
      ]
    },
    "STFT_METADATA": {
      "code": 10,
      "size_bytes": 48,
      "description": "fixed STFT tile layout and unambiguous frame-time convention",
      "fields": [
        {"name": "fft_size", "type": "u32", "offset": 8},
        {"name": "hop_size", "type": "u32", "offset": 12},
        {"name": "frame_count", "type": "u32", "offset": 16},
        {"name": "bin_count", "type": "u32", "offset": 20},
        {"name": "timestamp_reference", "type": "u8", "offset": 24},
        {"name": "window", "type": "u8", "offset": 25},
        {"name": "encoding", "type": "u8", "offset": 26},
        {"name": "stage_shift", "type": "u8", "offset": 27},
        {"name": "output_rate_hz", "type": "u32", "offset": 28},
        {"name": "first_frame_timestamp", "type": "u64", "offset": 32},
        {"name": "overflow_count", "type": "u32", "offset": 40},
        {"name": "reserved", "type": "u32", "offset": 44}
      ],
      "requirements": [
        "STFT packets carry exactly one STFT_METADATA extension",
        "frame timestamps advance by hop_size samples in the declared output rate domain"
      ]
    },
    "DETECTOR_EVENT": {
      "code": 11,
      "size_bytes": 52,
      "description": "fixed detector event record with the configuration revision that produced it",
      "fields": [
        {"name": "detector_id", "type": "u32", "offset": 8},
        {"name": "detector_revision", "type": "u32", "offset": 12},
        {"name": "event_kind", "type": "u16", "offset": 16},
        {"name": "channel", "type": "u8", "offset": 18},
        {"name": "event_flags", "type": "u8", "offset": 19},
        {"name": "frequency_hz", "type": "i64", "offset": 20},
        {"name": "magnitude_q16_16", "type": "u32", "offset": 28},
        {"name": "duration_samples", "type": "u32", "offset": 32},
        {"name": "start_timestamp", "type": "u64", "offset": 36},
        {"name": "end_timestamp", "type": "u64", "offset": 44}
      ],
      "requirements": [
        "DETECTOR_EVENT packets carry this extension and no payload",
        "base sample_timestamp equals start_timestamp"
      ]
    },
    "TRIGGER_CAPTURE": {
      "code": 12,
      "size_bytes": 52,
      "description": "triggered-capture identity and segment geometry",
      "fields": [
        {"name": "capture_id", "type": "u32", "offset": 8},
        {"name": "segment_index", "type": "u32", "offset": 12},
        {"name": "segment_count", "type": "u32", "offset": 16},
        {"name": "trigger_source", "type": "u16", "offset": 20},
        {"name": "capture_format", "type": "u8", "offset": 22},
        {"name": "capture_channel_mask", "type": "u8", "offset": 23},
        {"name": "trigger_timestamp", "type": "u64", "offset": 24},
        {"name": "first_timestamp", "type": "u64", "offset": 32},
        {"name": "pre_trigger_samples", "type": "u32", "offset": 40},
        {"name": "post_trigger_samples", "type": "u32", "offset": 44},
        {"name": "capture_flags", "type": "u32", "offset": 48}
      ],
      "requirements": [
        "TRIGGERED_CAPTURE IQ packets carry exactly one TRIGGER_CAPTURE extension",
        "segment indexes start at zero and are less than segment_count"
      ]
    },
    "STATUS_SNAPSHOT": {
      "code": 13,
      "size_bytes": 72,
      "description": "fixed low-rate health and fault counter snapshot",
      "fields": [
        {"name": "uptime_ticks", "type": "u64", "offset": 8, "description": "device uptime in timestamp_timebase_hz ticks; unlike NECP HEALTH.uptime_ns this field uses the NEDP hardware timebase"},
        {"name": "temperature_mc", "type": "i32", "offset": 16},
        {"name": "status_flags", "type": "u32", "offset": 20},
        {"name": "fault_flags", "type": "u32", "offset": 24},
        {"name": "fifo_high_watermark", "type": "u32", "offset": 28},
        {"name": "fifo_overflow_count", "type": "u32", "offset": 32},
        {"name": "dma_starvation_count", "type": "u32", "offset": 36},
        {"name": "packet_drop_count", "type": "u32", "offset": 40},
        {"name": "sample_discontinuity_count", "type": "u32", "offset": 44},
        {"name": "ethernet_backpressure_count", "type": "u32", "offset": 48},
        {"name": "clipping_count", "type": "u32", "offset": 52},
        {"name": "active_stream_mask", "type": "u32", "offset": 56},
        {"name": "fpga_build_id", "type": "u32", "offset": 60},
        {"name": "firmware_build_id", "type": "u32", "offset": 64},
        {"name": "ethernet_link_state", "type": "u8", "offset": 68},
        {"name": "usb_state", "type": "u8", "offset": 69},
        {"name": "pll_lock_mask", "type": "u8", "offset": 70},
        {"name": "reserved", "type": "u8", "offset": 71}
      ]
    },
    "DUAL_CHANNEL_PRODUCT": {
      "code": 14,
      "size_bytes": 40,
      "description": "cross-channel product geometry and scaling",
      "fields": [
        {"name": "product_kind", "type": "u16", "offset": 8},
        {"name": "encoding", "type": "u8", "offset": 10},
        {"name": "reserved8", "type": "u8", "offset": 11},
        {"name": "fft_size", "type": "u32", "offset": 12},
        {"name": "element_count", "type": "u32", "offset": 16},
        {"name": "averaging_count", "type": "u32", "offset": 20},
        {"name": "rx1_scale_q16_16", "type": "i32", "offset": 24},
        {"name": "rx2_scale_q16_16", "type": "i32", "offset": 28},
        {"name": "reference_timestamp", "type": "u64", "offset": 32}
      ]
    },
    "PAYLOAD_CRC": {
      "code": 255,
      "size_bytes": 16,
      "description": "optional CRC-32C over payload bytes only",
      "fields": [
        {"name": "payload_crc32c", "type": "u32", "offset": 8},
        {"name": "reserved", "type": "u32", "offset": 12}
      ]
    }
  },
  "sample_formats": {
    "S16": {
      "code": 1,
      "bits_per_complex_sample": 32,
      "layout": "signed int16 little-endian I then Q",
      "semantics": "native signed 12-bit ADC codes sign-extended in 16-bit containers"
    },
    "S12P": {
      "code": 2,
      "bits_per_complex_sample": 24,
      "layout": "three little-endian bytes from (I & 0xfff) | ((Q & 0xfff) << 12)",
      "semantics": "lossless for native signed 12-bit I/Q; corrected values outside [-2048, 2047] saturate and set CLIPPED rather than wrapping"
    },
    "S8": {
      "code": 3,
      "bits_per_complex_sample": 16,
      "layout": "signed int8 I then Q",
