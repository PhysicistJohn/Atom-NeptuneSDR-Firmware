{
  "schema": "neptunesdr.edge.control-schema/v1",
  "protocol": "Neptune Edge Control Plane v1",
  "status": "canonical wire contract",
  "transport": {
    "primary": "USB vendor-specific bulk",
    "recovery": "USB CDC ACM console",
    "framing": "one header followed by payload_length bytes of typed items",
    "byte_order": "little-endian"
  },
  "crc": {
    "algorithm": "CRC-32C (Castagnoli)",
    "reflected_polynomial": "0x82f63b78",
    "initial": "0xffffffff",
    "xor_out": "0xffffffff",
    "header_rule": "CRC-32C over the 40-byte base header with header_crc32c encoded as zero",
    "payload_rule": "CRC-32C over exactly payload_length payload bytes; CRC-32C of an empty payload is zero"
  },
  "base_header": {
    "magic_ascii": "NECP",
    "version": 1,
    "size_bytes": 40,
    "header_length_unit_bytes": 4,
    "fields": [
      {"name": "magic", "type": "bytes4", "offset": 0, "description": "ASCII NECP"},
      {"name": "protocol_version", "type": "u8", "offset": 4, "description": "exactly 1"},
      {"name": "header_words", "type": "u8", "offset": 5, "description": "exactly 10 for v1"},
      {"name": "message_kind", "type": "u8", "offset": 6, "description": "request, response, or asynchronous event"},
      {"name": "flags", "type": "u8", "offset": 7, "description": "ControlFlag bitset"},
      {"name": "command_id", "type": "u16", "offset": 8, "description": "Command code"},
      {"name": "status", "type": "u16", "offset": 10, "description": "zero on requests; Status code on responses"},
      {"name": "transaction_id", "type": "u32", "offset": 12, "description": "host-selected nonzero request ID copied into the response"},
      {"name": "payload_length", "type": "u32", "offset": 16, "description": "typed-item bytes following the header"},
      {"name": "configuration_revision", "type": "u32", "offset": 20, "description": "request expectation or resulting active revision"},
      {"name": "activation_timestamp", "type": "u64", "offset": 24, "description": "61.44 MHz ingress tick; UINT64_MAX requests the next safe boundary"},
      {"name": "payload_crc32c", "type": "u32", "offset": 32, "description": "CRC-32C over payload only"},
      {"name": "header_crc32c", "type": "u32", "offset": 36, "description": "CRC-32C over base header with this field zero"}
    ]
  },
  "item_header": {
    "size_bytes": 8,
    "length_unit_bytes": 4,
    "fields": [
      {"name": "type", "type": "u16", "offset": 0},
      {"name": "length_words", "type": "u16", "offset": 2},
      {"name": "flags", "type": "u32", "offset": 4}
    ],
    "rules": [
      "length_words includes the eight-byte item header",
      "items are ordered by ascending type code",
      "unknown optional items are skipped and unknown required items are rejected",
      "bit zero of item flags means REQUIRED"
    ]
  },
  "enums": {
    "message_kind": {
      "REQUEST": 1,
      "RESPONSE": 2,
      "EVENT": 3
    },
    "control_flag": {
      "ACK_REQUIRED": 1,
      "ATOMIC": 2,
      "SCHEDULED": 4,
      "ERROR_DETAIL_PRESENT": 8
    },
    "item_flag": {
      "REQUIRED": 1
    },
    "status": {
      "OK": 0,
      "INVALID_COMMAND": 1,
      "INVALID_LENGTH": 2,
      "INVALID_VALUE": 3,
      "REVISION_CONFLICT": 4,
      "UNSUPPORTED": 5,
      "BUSY": 6,
      "CRC_ERROR": 7,
      "AUTHORIZATION_REQUIRED": 8,
      "INTERNAL_ERROR": 9
    },
    "command": {
      "HELLO": 1,
      "GET_IDENTITY": 2,
      "GET_HEALTH": 3,
      "SET_RF": 256,
      "GET_RF": 257,
      "CONFIGURE_PIPELINE": 512,
      "CONFIGURE_DDC": 513,
      "CONFIGURE_FFT": 514,
      "CONFIGURE_STFT": 515,
      "CONFIGURE_NORMALIZATION": 516,
      "CONFIGURE_DETECTOR": 517,
      "LOAD_CALIBRATION": 768,
      "SELECT_CALIBRATION": 769,
      "CREATE_STREAM": 1024,
      "DESTROY_STREAM": 1025,
      "START_STREAM": 1026,
      "STOP_STREAM": 1027,
      "CONFIGURE_TRIGGER": 1280,
      "SOFTWARE_TRIGGER": 1281,
      "RESET_COUNTERS": 1536,
      "GET_COUNTERS": 1537,
      "READ_LOGS": 1538,
      "REBOOT": 1792,
      "ENTER_RECOVERY": 1793,
      "CONFIGURE_TX": 2048,
      "HARD_DISABLE_TX": 2049,
      "BEGIN_UPDATE": 2304,
      "WRITE_UPDATE_CHUNK": 2305,
      "COMMIT_UPDATE": 2306,
      "STATE_CHANGE_EVENT": 32768,
      "FAULT_EVENT": 32769
    },
    "gain_mode": {
      "MANUAL": 0,
      "SLOW_ATTACK": 1,
      "FAST_ATTACK": 2,
      "HYBRID": 3
    },
    "pipeline_block": {
      "RAW_TAP": 1,
      "DC_CORRECTION": 2,
      "IQ_CORRECTION": 4,
      "CHANNEL_CALIBRATION": 8,
      "EQUALIZER": 16,
      "VALIDITY": 32,
      "NORMALIZER": 64,
      "QUANTIZER": 128,
      "DDC": 256,
      "FFT_STFT": 512,
      "DETECTORS": 1024,
      "CROSS_CHANNEL": 2048
    },
    "normalization_strategy": {
      "FIXED_SHIFT": 0,
      "PEAK": 1,
      "RMS": 2
    },
    "stream_state": {
      "NONE": 0,
      "CREATED": 1,
      "RUNNING": 2
    },
    "system_action_kind": {
      "REBOOT": 1,
      "ENTER_RECOVERY": 2,
      "RESET_COUNTERS": 3,
      "HARD_DISABLE_TX": 4,
      "COMMIT_UPDATE": 5
    },
    "update_image_kind": {
      "SD_SLOT_IMAGE": 1,
      "BOOT_FILES": 2,
      "ROOTFS": 3
    }
  },
  "items": {
    "RF_CONFIG": {
      "code": 1,
      "size_bytes": 48,
      "description": "complete RF configuration; omitted fields are not inferred",
      "fields": [
        {"name": "center_frequency_hz", "type": "u64", "offset": 8},
        {"name": "internal_sample_rate_hz", "type": "u32", "offset": 16},
        {"name": "egress_sample_rate_hz", "type": "u32", "offset": 20},
        {"name": "rf_bandwidth_hz", "type": "u32", "offset": 24},
        {"name": "rx1_gain_mdb", "type": "i32", "offset": 28},
        {"name": "rx2_gain_mdb", "type": "i32", "offset": 32},
        {"name": "channel_mask", "type": "u16", "offset": 36},
        {"name": "rx1_gain_mode", "type": "u8", "offset": 38},
        {"name": "rx2_gain_mode", "type": "u8", "offset": 39},
        {"name": "expected_configuration_revision", "type": "u32", "offset": 40},
        {"name": "rf_flags", "type": "u32", "offset": 44}
      ],
      "constraints": {
        "internal_sample_rate_hz": [61440000],
        "egress_sample_rate_hz": [55000000],
        "channel_mask_min": 1,
        "channel_mask_max": 3,
        "tx_default": "disabled"
      }
    },
    "ATOMIC_COMMIT": {
      "code": 2,
      "size_bytes": 32,
      "description": "compare-and-commit request with sample-boundary activation",
      "fields": [
        {"name": "expected_configuration_revision", "type": "u32", "offset": 8},
        {"name": "expected_calibration_revision", "type": "u32", "offset": 12},
        {"name": "activate_at_timestamp", "type": "u64", "offset": 16},
        {"name": "changed_fields", "type": "u64", "offset": 24}
      ]
    },
    "STREAM_CONFIG": {
      "code": 3,
      "size_bytes": 40,
      "description": "UDP destination and logical product selection",
      "fields": [
        {"name": "stream_id", "type": "u32", "offset": 8},
        {"name": "destination_ipv4", "type": "bytes4", "offset": 12, "description": "four network-order IPv4 octets; byte arrays are not endian-swapped"},
        {"name": "destination_port", "type": "u16", "offset": 16},
        {"name": "mtu", "type": "u16", "offset": 18},
        {"name": "product_mask", "type": "u32", "offset": 20},
        {"name": "sample_format", "type": "u8", "offset": 24},
        {"name": "channel_mask", "type": "u8", "offset": 25},
        {"name": "reserved16", "type": "u16", "offset": 26},
        {"name": "packet_sample_count", "type": "u32", "offset": 28},
        {"name": "stream_flags", "type": "u32", "offset": 32},
        {"name": "reserved32", "type": "u32", "offset": 36}
      ]
    },
    "STATE_CHANGE": {
      "code": 4,
      "size_bytes": 40,
      "description": "control response/event reporting the exact accepted transition",
      "fields": [
        {"name": "previous_configuration_revision", "type": "u32", "offset": 8},
        {"name": "new_configuration_revision", "type": "u32", "offset": 12},
        {"name": "previous_calibration_revision", "type": "u32", "offset": 16},
        {"name": "new_calibration_revision", "type": "u32", "offset": 20},
        {"name": "activation_timestamp", "type": "u64", "offset": 24},
        {"name": "changed_fields", "type": "u64", "offset": 32}
      ]
    },
    "ERROR_DETAIL": {
      "code": 5,
      "size_bytes": 24,
      "description": "fixed machine-readable error context; no free-form string is required for parsing",
      "fields": [
        {"name": "field_id", "type": "u16", "offset": 8},
        {"name": "detail_code", "type": "u16", "offset": 10},
        {"name": "minimum", "type": "i32", "offset": 12},
        {"name": "maximum", "type": "i32", "offset": 16},
        {"name": "observed", "type": "i32", "offset": 20}
      ]
    },
    "IDENTITY": {
      "code": 6,
      "size_bytes": 112,
      "description": "immutable hardware and build identity plus exact protocol hashes",
      "fields": [
        {"name": "hardware_id", "type": "u32", "offset": 8},
        {"name": "hardware_revision", "type": "u32", "offset": 12},
        {"name": "fpga_build_id", "type": "u64", "offset": 16},
        {"name": "firmware_build_id", "type": "u64", "offset": 24},
        {"name": "protocol_data_sha256", "type": "bytes32", "offset": 32},
        {"name": "protocol_control_sha256", "type": "bytes32", "offset": 64},
        {"name": "calibration_revision", "type": "u32", "offset": 96},
        {"name": "capability_bits", "type": "u32", "offset": 100},
        {"name": "device_serial_hash", "type": "u64", "offset": 104}
      ]
    },
    "HEALTH": {
      "code": 7,
      "size_bytes": 80,
      "description": "fixed control-plane health and diagnostic counter snapshot",
      "fields": [
        {"name": "uptime_ns", "type": "u64", "offset": 8, "description": "nanoseconds from the boot-inclusive monotonic system clock (CLOCK_BOOTTIME on Linux); never an RF sample counter"},
        {"name": "temperature_mc", "type": "i32", "offset": 16},
        {"name": "status_flags", "type": "u32", "offset": 20},
        {"name": "fault_flags", "type": "u32", "offset": 24},
        {"name": "ethernet_link_state", "type": "u8", "offset": 28},
        {"name": "usb_state", "type": "u8", "offset": 29},
        {"name": "pll_lock_mask", "type": "u8", "offset": 30},
        {"name": "active_stream_mask", "type": "u8", "offset": 31},
        {"name": "fifo_overflow_count", "type": "u32", "offset": 32},
        {"name": "dma_overrun_count", "type": "u32", "offset": 36},
        {"name": "packet_drop_count", "type": "u32", "offset": 40},
        {"name": "sample_discontinuity_count", "type": "u32", "offset": 44},
        {"name": "clipping_count", "type": "u32", "offset": 48},
        {"name": "watchdog_reset_count", "type": "u32", "offset": 52},
        {"name": "supply_mv", "type": "u32", "offset": 56},
        {"name": "supply_ma", "type": "u32", "offset": 60},
        {"name": "calibration_revision", "type": "u32", "offset": 64},
        {"name": "configuration_revision", "type": "u32", "offset": 68},
        {"name": "reserved", "type": "u64", "offset": 72}
      ]
    },
    "PIPELINE_CONFIG": {
      "code": 8,
      "size_bytes": 48,
      "description": "complete pipeline enable, bypass, product, normalization, and validity policy",
      "fields": [
        {"name": "enable_mask", "type": "u32", "offset": 8},
        {"name": "bypass_mask", "type": "u32", "offset": 12},
        {"name": "output_product_mask", "type": "u32", "offset": 16},
        {"name": "sample_format", "type": "u8", "offset": 20},
        {"name": "normalization_strategy", "type": "u8", "offset": 21},
        {"name": "headroom_bits", "type": "u8", "offset": 22},
        {"name": "rounding_mode", "type": "u8", "offset": 23},
        {"name": "fixed_shift", "type": "u8", "offset": 24},
        {"name": "reserved8", "type": "u8", "offset": 25},
        {"name": "reserved16", "type": "u16", "offset": 26},
        {"name": "expected_configuration_revision", "type": "u32", "offset": 28},
        {"name": "calibration_revision", "type": "u32", "offset": 32},
        {"name": "pipeline_revision", "type": "u32", "offset": 36},
        {"name": "validity_policy", "type": "u32", "offset": 40},
        {"name": "pipeline_flags", "type": "u32", "offset": 44}
      ]
    },
    "DDC_CONFIG": {
      "code": 9,
      "size_bytes": 40,
      "description": "per-channel NCO, rate, decimation, and compensation-FIR configuration",
      "fields": [
        {"name": "channel_mask", "type": "u16", "offset": 8},
        {"name": "reserved16", "type": "u16", "offset": 10},
        {"name": "center_offset_hz", "type": "i32", "offset": 12},
        {"name": "input_rate_hz", "type": "u32", "offset": 16},
        {"name": "output_rate_hz", "type": "u32", "offset": 20},
        {"name": "decimation", "type": "u32", "offset": 24},
        {"name": "nco_phase_increment", "type": "u32", "offset": 28},
        {"name": "compensation_fir_bank", "type": "u32", "offset": 32},
        {"name": "ddc_revision", "type": "u32", "offset": 36}
      ]
    },
    "FFT_CONFIG": {
      "code": 10,
      "size_bytes": 40,
      "description": "FFT or STFT transform geometry; nonzero hop_size selects STFT scheduling",
      "fields": [
        {"name": "product_id", "type": "u32", "offset": 8},
        {"name": "fft_size", "type": "u32", "offset": 12},
        {"name": "hop_size", "type": "u32", "offset": 16},
        {"name": "window", "type": "u16", "offset": 20},
        {"name": "encoding", "type": "u8", "offset": 22},
        {"name": "channel_mask", "type": "u8", "offset": 23},
        {"name": "first_bin", "type": "i32", "offset": 24},
        {"name": "bin_count", "type": "u32", "offset": 28},
        {"name": "averaging_count", "type": "u32", "offset": 32},
        {"name": "transform_flags", "type": "u32", "offset": 36}
      ]
    },
    "NORMALIZATION_CONFIG": {
      "code": 11,
      "size_bytes": 40,
      "description": "deterministic fixed or block-floating quantizer configuration",
      "fields": [
        {"name": "strategy", "type": "u8", "offset": 8},
        {"name": "headroom_bits", "type": "u8", "offset": 9},
        {"name": "rounding_mode", "type": "u8", "offset": 10},
        {"name": "fixed_shift", "type": "u8", "offset": 11},
        {"name": "attack_blocks", "type": "u16", "offset": 12},
        {"name": "release_blocks", "type": "u16", "offset": 14},
        {"name": "block_sample_count", "type": "u32", "offset": 16},
        {"name": "rms_target_q16_16", "type": "u32", "offset": 20},
        {"name": "peak_target_q16_16", "type": "u32", "offset": 24},
        {"name": "minimum_exponent", "type": "i16", "offset": 28},
        {"name": "maximum_exponent", "type": "i16", "offset": 30},
        {"name": "normalization_revision", "type": "u32", "offset": 32},
        {"name": "normalization_flags", "type": "u32", "offset": 36}
      ]
    },
    "DETECTOR_CONFIG": {
      "code": 12,
      "size_bytes": 48,
      "description": "fixed detector configuration and revision",
      "fields": [
        {"name": "detector_id", "type": "u32", "offset": 8},
        {"name": "detector_revision", "type": "u32", "offset": 12},
        {"name": "detector_kind", "type": "u16", "offset": 16},
        {"name": "channel_mask", "type": "u16", "offset": 18},
        {"name": "threshold_q16_16", "type": "u32", "offset": 20},
        {"name": "hysteresis_q16_16", "type": "u32", "offset": 24},
        {"name": "integration_samples", "type": "u32", "offset": 28},
        {"name": "holdoff_samples", "type": "u32", "offset": 32},
        {"name": "first_bin", "type": "u32", "offset": 36},
        {"name": "bin_count", "type": "u32", "offset": 40},
        {"name": "detector_flags", "type": "u32", "offset": 44}
      ]
    },
    "TRIGGER_CONFIG": {
      "code": 13,
      "size_bytes": 56,
      "description": "raw/corrected DDR capture geometry and trigger selection",
      "fields": [
        {"name": "capture_id", "type": "u32", "offset": 8},
        {"name": "trigger_source", "type": "u16", "offset": 12},
        {"name": "channel_mask", "type": "u8", "offset": 14},
        {"name": "sample_format", "type": "u8", "offset": 15},
        {"name": "pre_trigger_samples", "type": "u32", "offset": 16},
        {"name": "post_trigger_samples", "type": "u32", "offset": 20},
        {"name": "trigger_timestamp", "type": "u64", "offset": 24},
        {"name": "detector_id", "type": "u32", "offset": 32},
        {"name": "gpio_index", "type": "u32", "offset": 36},
        {"name": "capture_revision", "type": "u32", "offset": 40},
        {"name": "capture_flags", "type": "u32", "offset": 44},
        {"name": "reserved", "type": "u64", "offset": 48}
      ]
    },
    "CALIBRATION_DESCRIPTOR": {
      "code": 14,
      "size_bytes": 80,
      "description": "identity and integrity metadata for a chunked calibration bundle upload",
      "fields": [
        {"name": "transfer_id", "type": "u32", "offset": 8},
        {"name": "bundle_length", "type": "u32", "offset": 12},
        {"name": "bundle_sha256", "type": "bytes32", "offset": 16},
        {"name": "signature_scheme", "type": "u16", "offset": 48},
        {"name": "signature_length", "type": "u16", "offset": 50},
        {"name": "calibration_revision", "type": "u32", "offset": 52},
        {"name": "device_serial_hash", "type": "u64", "offset": 56},
        {"name": "calibration_flags", "type": "u32", "offset": 64},
        {"name": "reserved", "type": "u32", "offset": 68},
        {"name": "activation_timestamp", "type": "u64", "offset": 72}
      ]
    },
    "CALIBRATION_CHUNK": {
      "code": 15,
      "size_bytes": 284,
      "description": "fixed-size upload item; bytes beyond chunk_length must be zero",
      "fields": [
        {"name": "transfer_id", "type": "u32", "offset": 8},
        {"name": "total_length", "type": "u32", "offset": 12},
        {"name": "chunk_offset", "type": "u32", "offset": 16},
        {"name": "chunk_length", "type": "u16", "offset": 20},
        {"name": "reserved16", "type": "u16", "offset": 22},
        {"name": "chunk_crc32c", "type": "u32", "offset": 24},
        {"name": "data", "type": "bytes256", "offset": 28}
      ]
    },
    "CALIBRATION_SELECT": {
      "code": 16,
      "size_bytes": 56,
      "description": "select a verified persistent calibration revision at an exact sample timestamp",
      "fields": [
        {"name": "calibration_revision", "type": "u32", "offset": 8},
        {"name": "expected_calibration_revision", "type": "u32", "offset": 12},
        {"name": "bundle_sha256", "type": "bytes32", "offset": 16},
        {"name": "activation_timestamp", "type": "u64", "offset": 48}
      ]
    },
    "STREAM_STATUS": {
      "code": 17,
      "size_bytes": 48,
      "description": "current logical stream state and transport counters",
      "fields": [
        {"name": "stream_id", "type": "u32", "offset": 8},
        {"name": "stream_state", "type": "u32", "offset": 12},
        {"name": "sequence_number", "type": "u64", "offset": 16},
        {"name": "sample_timestamp", "type": "u64", "offset": 24},
        {"name": "packet_count", "type": "u64", "offset": 32},
        {"name": "drop_count", "type": "u32", "offset": 40},
        {"name": "last_error", "type": "u32", "offset": 44}
      ]
    },
    "COUNTER_SNAPSHOT": {
      "code": 18,
      "size_bytes": 64,
      "description": "sticky diagnostics retained until an explicit reset command succeeds",
      "fields": [
        {"name": "fifo_high_watermark", "type": "u32", "offset": 8},
        {"name": "fifo_overflow_count", "type": "u32", "offset": 12},
        {"name": "dma_starvation_count", "type": "u32", "offset": 16},
        {"name": "ddr_capture_overrun_count", "type": "u32", "offset": 20},
        {"name": "ethernet_backpressure_count", "type": "u32", "offset": 24},
        {"name": "packet_drop_count", "type": "u32", "offset": 28},
        {"name": "malformed_frame_count", "type": "u32", "offset": 32},
        {"name": "sample_discontinuity_count", "type": "u32", "offset": 36},
        {"name": "clipping_count", "type": "u64", "offset": 40},
        {"name": "rx_sample_count", "type": "u64", "offset": 48},
        {"name": "tx_sample_count", "type": "u64", "offset": 56}
      ]
    },
    "SYSTEM_ACTION": {
      "code": 19,
      "size_bytes": 24,
      "description": "explicit destructive or recovery action with a caller-provided audit reason",
      "fields": [
        {"name": "action_kind", "type": "u16", "offset": 8},
        {"name": "action_flags", "type": "u16", "offset": 10},
        {"name": "reason_code", "type": "u32", "offset": 12},
        {"name": "authorization_token", "type": "u64", "offset": 16}
      ]
    },
    "UPDATE_DESCRIPTOR": {
      "code": 20,
      "size_bytes": 104,
      "description": "signed A/B removable-SD update identity and rollback policy",
      "fields": [
        {"name": "transfer_id", "type": "u32", "offset": 8},
        {"name": "image_kind", "type": "u16", "offset": 12},
        {"name": "target_slot", "type": "u8", "offset": 14},
        {"name": "reserved8", "type": "u8", "offset": 15},
        {"name": "image_length", "type": "u64", "offset": 16},
        {"name": "rollback_index", "type": "u64", "offset": 24},
        {"name": "image_sha256", "type": "bytes32", "offset": 32},
        {"name": "manifest_sha256", "type": "bytes32", "offset": 64},
        {"name": "update_flags", "type": "u32", "offset": 96},
        {"name": "reserved", "type": "u32", "offset": 100}
      ]
    },
    "UPDATE_CHUNK": {
      "code": 21,
      "size_bytes": 284,
      "description": "fixed-size signed-update transport item; bytes beyond chunk_length must be zero",
      "fields": [
        {"name": "transfer_id", "type": "u32", "offset": 8},
        {"name": "total_length", "type": "u32", "offset": 12},
        {"name": "chunk_offset", "type": "u32", "offset": 16},
        {"name": "chunk_length", "type": "u16", "offset": 20},
        {"name": "reserved16", "type": "u16", "offset": 22},
        {"name": "chunk_crc32c", "type": "u32", "offset": 24},
        {"name": "data", "type": "bytes256", "offset": 28}
      ]
